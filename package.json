{
  "name": "@travi/cli",
  "description": "cli for my various tools",
  "license": "MIT",
  "version": "0.0.0-semantically-released",
  "type": "module",
  "engines": {
    "node": "^22.22.2 || >=24.15"
  },
  "author": "Matt Travi <npm@travi.org> (https://matt.travi.org/)",
  "repository": "travi/cli",
  "bugs": "https://github.com/travi/cli/issues",
  "homepage": "https://www.npmjs.com/package/@travi/cli",
  "bin": {
    "travi": "bin/travi.js"
  },
  "scripts": {
    "test": "npm-run-all --print-label --parallel lint:* --parallel test:*",
    "lint:engines": "ls-engines",
    "lint:gherkin": "gplint --config .gplintrc.json",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "run-s 'lint:js -- --fix'",
    "lint:lockfile": "lockfile-lint",
    "lint:md": "remark . --frail",
    "lint:peer": "npm ls >/dev/null",
    "prelint:publish": "run-s build",
    "lint:publish": "publint --strict",
    "pretest:e2e": "run-s build",
    "test:e2e": "node ./test/e2e/smoke-test.js",
    "test:unit": "run-s 'test:unit:base -- --coverage'",
    "test:unit:base": "NODE_ENV=test DEBUG=any vitest run src/",
    "test:integration": "run-s 'test:integration:base -- --profile noWip'",
    "test:integration:base": "NODE_OPTIONS=--enable-source-maps DEBUG=any cucumber-js test/integration",
    "test:integration:debug": "DEBUG=nock.* run-s test:integration",
    "test:integration:focus": "run-s 'test:integration:base -- --profile focus'",
    "test:integration:wip": "run-s 'test:integration:base -- --profile wip'",
    "build": "run-s clean build:*",
    "build:js": "rollup -c",
    "clean": "rimraf bin/",
    "generate:md": "remark . --output",
    "prepack": "run-s build",
    "prepare": "husky",
    "snyk-protect": "snyk protect",
    "watch": "run-s 'build:js -- --watch'"
  },
  "files": [
    "bin/"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "packageManager": "npm@11.17.0+sha512.3eeaf18997b11070d313849268b23766b9db0068997dec9471073170fe43fa17f2b4d0337bf0f52330ee2274e7f5754b21b01052742e48f5c9c74d8b1e32ef43",
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@form8ion/add-package-to-monorepo": "14.0.0-beta.7",
    "@form8ion/cli-core": "1.1.1",
    "@form8ion/core": "5.0.0-beta.15",
    "@form8ion/cucumber-scaffolder": "5.9.0",
    "@form8ion/cypress-scaffolder": "4.0.0",
    "@form8ion/dependabot-scaffolder": "3.0.0",
    "@form8ion/eslint-config-extender": "12.0.0-beta.8",
    "@form8ion/github": "4.0.0-beta.1",
    "@form8ion/github-actions-node-ci": "5.0.4",
    "@form8ion/github-core": "2.0.0",
    "@form8ion/hapi-scaffolder": "5.0.0-alpha.7",
    "@form8ion/javascript": "16.0.0-beta.10",
    "@form8ion/javascript-core": "13.0.0",
    "@form8ion/jest-scaffolder": "2.0.0",
    "@form8ion/jetbrains": "1.1.4",
    "@form8ion/lerna": "3.0.0",
    "@form8ion/lift": "12.0.0-beta.6",
    "@form8ion/mdx-deck": "1.1.2",
    "@form8ion/mocha-scaffolder": "6.1.1",
    "@form8ion/nuxt": "2.0.0",
    "@form8ion/octoherd-script": "1.0.0",
    "@form8ion/ossf-scorecard": "1.2.2",
    "@form8ion/php": "1.9.1",
    "@form8ion/probot-scaffolder": "1.0.0-alpha.5",
    "@form8ion/project": "22.0.0-beta.20",
    "@form8ion/react-components-scaffolder": "4.0.0",
    "@form8ion/remove-greenkeeper": "3.0.1",
    "@form8ion/renovate-scaffolder": "3.0.1",
    "@form8ion/replace-travis-ci-with-github-actions": "10.0.1",
    "@form8ion/results-reporter": "1.1.0",
    "@form8ion/rollup": "6.0.1",
    "@form8ion/ruby-scaffolder": "2.1.0",
    "@form8ion/scaffolder-scaffolder": "7.0.5",
    "@form8ion/shuttle": "1.0.2",
    "@form8ion/ski-patrol": "1.0.0-alpha.5",
    "@form8ion/slidev": "3.0.0-alpha.1",
    "@form8ion/sno-cat-ink": "1.0.0-alpha.3",
    "@form8ion/vite": "3.0.1",
    "@form8ion/vitest": "6.6.1",
    "@travi/circle-scaffolder-javascript": "1.2.2",
    "@travi/gitlab-scaffolder": "1.1.1",
    "@travi/netlify-scaffolder": "1.6.0",
    "@travi/node-app-engine-standard-scaffolder": "3.0.1",
    "@travi/shell-scaffolder": "2.0.4",
    "@travi/spectacle-scaffolder": "6.0.2",
    "@travi/travis-scaffolder-shell": "1.0.0-alpha.4",
    "commander": "15.0.0",
    "inquander": "1.1.1",
    "snyk": "^1.355.0",
    "update-notifier": "7.3.1"
  },
  "devDependencies": {
    "@cucumber/cucumber": "13.0.0",
    "@form8ion/config-file": "1.3.0",
    "@form8ion/eslint-config-vitest": "1.1.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@travi/any": "3.3.0",
    "@travi/eslint-config": "5.0.17",
    "@travi/eslint-config-cucumber": "1.0.6",
    "@vitest/coverage-v8": "4.1.9",
    "chai": "6.2.2",
    "clear-module": "4.1.3",
    "commitlint-config-travi": "1.4.67",
    "cz-conventional-changelog": "3.3.0",
    "deep-equal": "2.2.3",
    "execa": "9.6.1",
    "get-bin-path": "11.0.1",
    "globstar": "1.0.0",
    "gplint": "2.5.2",
    "http-status-codes": "2.3.0",
    "husky": "9.1.7",
    "import-fresh": "4.0.0",
    "js-yaml": "4.2.0",
    "lockfile-lint": "5.0.0",
    "ls-engines": "0.10.0",
    "mdast-util-from-markdown": "2.0.3",
    "mock-fs": "5.5.0",
    "msw": "2.14.6",
    "npm-run-all2": "9.0.2",
    "publint": "0.3.21",
    "remark-cli": "12.0.1",
    "remark-preset-lint-travi": "6.0.8",
    "remark-toc": "9.0.0",
    "rimraf": "6.1.3",
    "rollup": "4.62.0",
    "rollup-plugin-auto-external": "2.0.0",
    "rollup-plugin-executable": "1.6.3",
    "rollup-plugin-json": "4.0.0",
    "sinon": "22.0.0",
    "testdouble": "3.20.2",
    "unist-util-find": "3.0.0",
    "vitest": "4.1.9",
    "vitest-when": "0.10.0"
  },
  "snyk": true
}
